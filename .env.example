# ============================================================
# AI BOILERPLATE - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- INFRA & SECURITY ---
DB_PASSWORD=secret_postgres_pass
DATABASE_URL=postgresql+asyncpg://admin:${DB_PASSWORD}@db:5432/ia_database
REDIS_URL=redis://redis:6379/0
JWT_SECRET=super_secret_string_for_jwt_tokens

# --- AI GATEWAY CONFIGURATION ---
# Cambiar esta variable altera el cerebro de toda la app sin tocar código Python.
# Ejemplos válidos: "ollama/llama3", "gpt-4o", "claude-3-7-sonnet", "gemini-1.5-pro", "ovh/mixtral"
ACTIVE_LLM_PROVIDER="ollama/llama3"

# 1. IA Local / Self-Hosted (Zero-Trust)
OLLAMA_API_BASE="http://ia_local:11434"

# 2. Infraestructura Soberana Europea (OVH Cloud)
OVH_AI_API_KEY="sk-ovh-..."
OVH_AI_BASE_URL="https://llama-3-70b-instruct.endpoints.kepler.ai.cloud.ovh.net/api/openai_compat/v1"

# 3. Modelos Comerciales de Terceros
OPENAI_API_KEY="sk-proj-..."
ANTHROPIC_API_KEY="sk-ant-..."
GEMINI_API_KEY="AIzaSy..."

# 4. Agentes Autónomos Asíncronos
MANUS_API_KEY="sk-manus-..."
MANUS_API_URL="https://api.manus.ai/v1/tasks"
MANUS_WEBHOOK_SECRET="whsec_..."

# --- FRONTEND ---
VITE_API_URL="http://localhost:8000"
